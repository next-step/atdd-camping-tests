{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/v1/payments/confirm",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$[?(@.amount >= 999999)]"
      }
    ]
  },
  "response": {
    "status": 400,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "code": "PAYMENT_DECLINED",
      "message": "Payment declined"
    }
  }
}
