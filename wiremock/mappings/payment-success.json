{
  "request": {
    "method": "POST",
    "urlPath": "/payments"
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "status": "APPROVED",
      "paymentId": "{{randomValue type='UUID'}}",
      "amount": "{{jsonPath request.body '$.amount'}}",
      "timestamp": "{{now format='yyyy-MM-dd HH:mm:ss'}}"
    }
  }
}
