{
  "request": {
    "method": "POST",
    "urlPath": "/v1/payments/confirm",
    "bodyPatterns": [
      {
        "equalToJson": {
          "paymentKey": "wrong_key"
        },
        "ignoreExtraElements": true
      }
    ]
  },
  "response": {
    "status": 400,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "message": "Invalid payment key"
    }
  }
}
