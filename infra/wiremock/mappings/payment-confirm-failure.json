{
  "request": {
    "method": "POST",
    "urlPath": "/v1/payments/confirm",
    "bodyPatterns": [
      {
        "equalToJson": "{\"amount\": \"12345\"}",
        "ignoreExtraElements": true
      }
    ]
  },
  "response": {
    "status": 400,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "success": false,
      "message": "결제 확정 실패",
      "error": "Invalid amount"
    }
  }
}