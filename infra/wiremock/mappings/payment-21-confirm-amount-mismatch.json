    "headers": { "Authorization": { "equalTo": "Basic dGVzdF9za19kdW1teTo=" } },
    "bodyPatterns": [ { "matchesJsonPath": "$[?(@.amount == 99999)]" } ]
  },
  "response": {
    "status": 409,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": { "code": "AMOUNT_MISMATCH", "message": "amount/orderId mismatch" }
  }
}
