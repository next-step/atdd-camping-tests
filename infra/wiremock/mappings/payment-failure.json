{
  "request": {
    "method": "POST",
    "url": "/api/external/payment/confirm",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.amount",
        "equalTo": "0"
      }
    ]
  },
  "response": {
    "status": 400,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "payment-failure-response.json"
  }
}