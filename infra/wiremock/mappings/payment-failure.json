{
  "request": {
    "method": "POST",
    "urlPath": "/v1/payments",
    "headers": {
      "Content-Type": {
        "equalTo": "application/json"
      }
    },
    "bodyPatterns": [
      {
        "matchesJsonPath": "$[?(@.amount == 0)]"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "payment-failure-response.json"
  },
  "priority": 1
}