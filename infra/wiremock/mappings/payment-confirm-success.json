{
  "request": {
    "method": "POST",
    "urlPath": "/v1/payments/confirm",
    "bodyPatterns": [
      {
        "equalToJson": "{\"amount\": \"10000\"}",
        "ignoreExtraElements": true
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "success": true,
      "message": "결제 확정 성공",
      "transactionId": "pay_123456789",
      "status": "CONFIRMED"
    }
  }
}
