{
  "request": {
    "method": "POST",
    "urlPath": "/v1/payments/confirm",
    "headers": {
      "Content-Type": {
        "equalTo": "application/json"
      }
    },
    "bodyPatterns": [
      {
        "matchesJsonPath": "$[?(@.paymentKey != 'unknown')]"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "payment-confirm-success-response.json"
  }
}