{
  "request": {
    "method": "POST",
    "url": "/api/external/payment/confirm",
    "headers": {
      "Content-Type": {"equalTo": "application/json"}
    },
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.amount",
        "doesNotMatch": "0"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "payment-success-response.json"
  }
}