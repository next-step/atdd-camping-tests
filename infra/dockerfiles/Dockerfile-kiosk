# Build stage
FROM eclipse-temurin:17-jdk AS build
WORKDIR /home/gradle/project
COPY ./repos/atdd-camping-kiosk /home/gradle/project
RUN chmod +x ./gradlew && ./gradlew bootJar

# Package stage
FROM eclipse-temurin:17-jre
WORKDIR /app
COPY --from=build /home/gradle/project/build/libs/*.jar /app/kiosk.jar
ENTRYPOINT ["java", "-jar", "/app/kiosk.jar"]
